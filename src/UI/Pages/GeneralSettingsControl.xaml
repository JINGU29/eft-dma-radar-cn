                                        <!-- Aimbot FOV & Aimbot Lock -->
                                        <TextBlock Text="自瞄视野" Grid.Row="4" Grid.Column="0" 
                                                   Style="{StaticResource ColorPickerLabel}"/>
                                        <Button x:Name="btnAimbotFOVColor" Grid.Row="4" Grid.Column="1" Tag="AimbotFOV"
                                                Style="{StaticResource ColorPickerButton}">
                                            <Button.Background>
                                                <SolidColorBrush x:Name="aimbotFOVBrush" Color="WhiteSmoke"/>
                                            </Button.Background>
                                        </Button>

                                        <TextBlock Text="自瞄锁定" Grid.Row="4" Grid.Column="3" 
                                                   Style="{StaticResource ColorPickerLabel}"/>
                                        <Button x:Name="btnAimbotLockColor" Grid.Row="4" Grid.Column="4" Tag="AimbotLock"
                                                Style="{StaticResource ColorPickerButton}">
                                            <Button.Background>
                                                <SolidColorBrush x:Name="aimbotLockBrush" Color="WhiteSmoke"/>
                                            </Button.Background>
                                        </Button>

                                        <!-- Closest Player & Top Loot -->
                                        <TextBlock Text="最近玩家" Grid.Row="5" Grid.Column="0" 
                                                   Style="{StaticResource ColorPickerLabel}"/>
                                        <Button x:Name="btnClosestPlayerColor" Grid.Row="5" Grid.Column="1" Tag="ClosestPlayer"
                                                Style="{StaticResource ColorPickerButton}">
                                            <Button.Background>
                                                <SolidColorBrush x:Name="closestPlayerBrush" Color="WhiteSmoke"/>
                                            </Button.Background>
                                        </Button>

                                        <TextBlock Text="顶级战利品" Grid.Row="5" Grid.Column="3" 
                                                   Style="{StaticResource ColorPickerLabel}"/>
                                        <Button x:Name="btnTopLootColor" Grid.Row="5" Grid.Column="4" Tag="TopLoot"
                                                Style="{StaticResource ColorPickerButton}">
                                            <Button.Background>
                                                <SolidColorBrush x:Name="topLootBrush" Color="WhiteSmoke"/>
                                            </Button.Background>
                                        </Button>

                                        <!-- Mini Radar Theme & Override Player Text -->
                                        <TextBlock Text="雷达主题" Grid.Row="6" Grid.Column="0"
                                                   Style="{StaticResource ColorPickerLabel}"/>
                                        <Button x:Name="btnMiniRadarThemeColor" Grid.Row="6" Grid.Column="1" Tag="MiniRadarTheme"
                                                Style="{StaticResource ColorPickerButton}">
                                            <Button.Background>
                                                <SolidColorBrush x:Name="miniRadarThemeBrush" Color="WhiteSmoke"/>
                                            </Button.Background>
                                        </Button>

                                        <TextBlock Text="覆盖玩家文本" Grid.Row="6" Grid.Column="3"
                                                   Style="{StaticResource ColorPickerLabel}"/>
                                        <Button x:Name="btnOverridePlayerTextColor" Grid.Row="6" Grid.Column="4" Tag="OverridePlayerText"
                                                Style="{StaticResource ColorPickerButton}">
                                            <Button.Background>
                                                <SolidColorBrush x:Name="overridePlayerTextBrush" Color="White"/>
                                            </Button.Background>
                                        </Button>
                                    </Grid>
                                </hc:SimpleStackPanel>
                            </Expander>

                            <!-- 界面颜色 -->
                            <Expander x:Name="expInterfaceColors" Header="界面颜色" Style="{StaticResource PanelExpander}" IsExpanded="True">
                                <hc:SimpleStackPanel Style="{StaticResource ExpanderContent}" Margin="2,8,2,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Primary accent -->
                                        <TextBlock Text="主色调" Grid.Row="0" Grid.Column="0" 
                                                   Style="{StaticResource ColorPickerLabel}"/>
                                        <Button x:Name="btnAccentColor" Grid.Row="0" Grid.Column="1" Tag="Interface.Accent"
                                                Style="{StaticResource ColorPickerButton}">
                                            <Button.Background>
                                                <SolidColorBrush x:Name="accentColor" Color="#0094FF"/>
                                            </Button.Background>
                                        </Button>

                                        <!-- Region colors -->
                                        <TextBlock Text="区域" Grid.Row="1" Grid.Column="0" 
                                                   Style="{StaticResource ColorPickerLabel}"/>
                                        <Button x:Name="btnRegionColor" Grid.Row="1" Grid.Column="1" Tag="Interface.Region"
                                                Style="{StaticResource ColorPickerButton}">
                                            <Button.Background>
                                                <SolidColorBrush x:Name="regionColor" Color="#222222"/>
                                            </Button.Background>
                                        </Button>

                                        <TextBlock Text="次要区域" Grid.Row="1" Grid.Column="3" 
                                                  Style="{StaticResource ColorPickerLabel}"/>
                                        <Button x:Name="btnSecondaryRegionColor" Grid.Row="1" Grid.Column="4" Tag="Interface.SecondaryRegion"
                                               Style="{StaticResource ColorPickerButton}">
                                            <Button.Background>
                                                <SolidColorBrush x:Name="secondaryRegionColor" Color="#333333"/>
                                            </Button.Background>
                                        </Button>

                                        <!-- Border color -->
                                        <TextBlock Text="边框" Grid.Row="2" Grid.Column="0" 
                                                   Style="{StaticResource ColorPickerLabel}"/>
                                        <Button x:Name="btnBorderColor" Grid.Row="2" Grid.Column="1" Tag="Interface.Border"
                                                Style="{StaticResource ColorPickerButton}">
                                            <Button.Background>
                                                <SolidColorBrush x:Name="borderColor" Color="#444444"/>
                                            </Button.Background>
                                        </Button>

                                        <!-- Radar Background color -->
                                        <TextBlock Text="雷达背景" Grid.Row="3" Grid.Column="0" 
                                                   Style="{StaticResource ColorPickerLabel}"/>
                                        <Button x:Name="btnRadarBackgroundColor" Grid.Row="3" Grid.Column="1" Tag="Interface.RadarBackground"
                                                Style="{StaticResource ColorPickerButton}">
                                            <Button.Background>
                                                <SolidColorBrush x:Name="radarBackgroundColor" Color="#000000"/>
                                            </Button.Background>
                                        </Button>

                                        <!-- Fuser Background color -->
                                        <TextBlock Text="融合器背景" Grid.Row="3" Grid.Column="3" 
                                                   Style="{StaticResource ColorPickerLabel}"/>
                                        <Button x:Name="btnFuserBackgroundColor" Grid.Row="3" Grid.Column="4" Tag="Interface.FuserBackground"
                                                Style="{StaticResource ColorPickerButton}">
                                            <Button.Background>
                                                <SolidColorBrush x:Name="fuserBackgroundColor" Color="#000000"/>
                                            </Button.Background>
                                        </Button>
                                    </Grid>
                                </hc:SimpleStackPanel>
                            </Expander>
                        </hc:SimpleStackPanel>
                    </ScrollViewer>
                </hc:TabItem>

                <!-- Hotkeys Tab -->
                <hc:TabItem Header="快捷键">
                    <ScrollViewer Style="{StaticResource PanelScrollViewer}">
                        <hc:SimpleStackPanel>
                            <Expander x:Name="expApplicationHotkeys" Header="应用快捷键" Style="{StaticResource PanelExpander}" IsExpanded="True">
                                <hc:SimpleStackPanel Style="{StaticResource ExpanderContent}" Margin="2,8,2,0">
                                    <!-- Hotkey Configuration -->
                                    <GroupBox Header="快捷键配置" Style="{StaticResource TransparentGroupBoxStyle}"
                                              Padding="8,5,8,8" Margin="0,0,0,15">
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Action Selection -->
                                            <TextBlock Text="操作:" Grid.Row="0" Grid.Column="0" 
                                                       Style="{StaticResource LabelText}"
                                                       VerticalAlignment="Center" 
                                                       Margin="0,0,8,0"/>

                                            <ComboBox x:Name="cboAction" Grid.Row="0" Grid.Column="1"
                                                      DisplayMemberPath="Name"
                                                      SelectedValuePath="Key"
                                                      hc:InfoElement.Placeholder="选择操作"
                                                      Margin="0,0,15,0"/>

                                            <!-- Key Selection -->
                                            <controls:KeyInputBox x:Name="keyInputBox" 
                                                Grid.Row="0" Grid.Column="3"
                                                PlaceholderText="选择按键"/>

                                            <!-- Hotkey Type -->
                                            <TextBlock Text="类型:" Grid.Row="1" Grid.Column="0" 
                                                       Style="{StaticResource LabelText}"
                                                       VerticalAlignment="Top" 
                                                       Margin="0,9,8,0" Height="18"/>

                                            <hc:SimpleStackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" 
                                                                 Orientation="Horizontal" 
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,10,0,15">
                                                <RadioButton x:Name="rdbOnKey" 
                                                             Content="按住" 
                                                             Margin="0,0,10,0" 
                                                             IsChecked="True"/>
                                                <RadioButton x:Name="rdbToggle" Content="切换"/>
                                            </hc:SimpleStackPanel>

                                            <!-- Action Buttons -->
                                            <hc:SimpleStackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4"
                                                                 Orientation="Horizontal" 
                                                                 HorizontalAlignment="Right" 
                                                                 Margin="0,0,1,0">
                                                <Button x:Name="btnRemoveHotkey" Content="移除快捷键"
                                                        Margin="0,0,10,0"
                                                        Style="{StaticResource ButtonPrimary}"/>
                                                <Button x:Name="btnAddHotkey" Content="添加快捷键"
                                                        Style="{StaticResource ButtonPrimary}" Width="94"/>
                                            </hc:SimpleStackPanel>
                                        </Grid>
                                    </GroupBox>

                                    <!-- Hotkeys Display Table -->
                                    <Border Style="{StaticResource ContainerListBorder}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <!-- Headers -->
                                            <Grid Grid.Row="0" Background="{DynamicResource RegionBrush}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="操作" Grid.Column="0" Style="{StaticResource LabelText}"
                                                           FontWeight="Bold" Padding="10,5"/>
                                                <TextBlock Text="按键" Grid.Column="1" Style="{StaticResource LabelText}"
                                                           FontWeight="Bold" Padding="10,5"/>
                                                <TextBlock Text="类型" Grid.Column="2" Style="{StaticResource LabelText}"
                                                           FontWeight="Bold" Padding="10,5"/>
                                            </Grid>

                                            <!-- Bindable Hotkey List -->
                                            <ListView Grid.Row="1" x:Name="hotkeyListView"
                                                      BorderThickness="0" Background="Transparent"
                                                      Height="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                                                <ListView.ItemContainerStyle>
                                                    <Style TargetType="ListViewItem">
                                                        <Setter Property="Padding" Value="2,2"/>
                                                        <Setter Property="MinHeight" Value="24"/>
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    </Style>
                                                </ListView.ItemContainerStyle>

                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Action}" Grid.Column="0" Style="{StaticResource LabelText}" Margin="5,0"/>
                                                            <TextBlock Text="{Binding Key}" Grid.Column="1" Style="{StaticResource LabelText}" Margin="5,0"/>
                                                            <TextBlock Text="{Binding Type}" Grid.Column="2" Style="{StaticResource LabelText}" Margin="5,0"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </Grid>
                                    </Border>
                                </hc:SimpleStackPanel>
                            </Expander>
                        </hc:SimpleStackPanel>
                    </ScrollViewer>
                </hc:TabItem>
                
                <!-- Config Tab -->
                <hc:TabItem Header="配置">
                    <ScrollViewer Style="{StaticResource PanelScrollViewer}">
                        <hc:SimpleStackPanel>
                            <Expander x:Name="expConfigManagement" Header="配置管理" 
                                      Style="{StaticResource PanelExpander}" IsExpanded="True">
                                <hc:SimpleStackPanel Style="{StaticResource ExpanderContent}" Margin="2,8,2,0">
                                    <!-- Current Config Display -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="当前配置:" Style="{StaticResource LabelText}" 
                                                   VerticalAlignment="Center" Grid.Column="0"/>
                                        <TextBlock x:Name="txtCurrentConfig" Text="config-eft-v3.json" 
                                                   Style="{StaticResource LabelText}" Grid.Column="1"
                                                   Margin="5,0,0,0"/>
                                    </Grid>

                                    <!-- Config Selection -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="Auto" MinWidth="37"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="可用配置:" Style="{StaticResource LabelText}" 
                                                   VerticalAlignment="Top" Grid.Column="0" Height="17" Margin="0,4,0,0"/>
                                        <ComboBox x:Name="cboConfigs" Grid.Column="1" Margin="5,0,5,0"
                                                  hc:InfoElement.Placeholder="选择配置"/>
                                        <Button x:Name="btnRefreshConfigs" Tag="RefreshConfigs" 
                                                Grid.Column="2"
                                                Style="{StaticResource ButtonIcon}"
                                                Width="37" Height="28"
                                                ToolTip="刷新配置"
                                                hc:IconElement.Geometry="{StaticResource RotateRightGeometry}"
                                                hc:IconElement.Width="16"
                                                hc:IconElement.Height="16"/>
                                    </Grid>

                                    <!-- New Config Name -->
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="新配置名称:" Style="{StaticResource LabelText}" 
                                                   VerticalAlignment="Center" Grid.Column="0"/>
                                        <hc:TextBox x:Name="txtNewConfigName" Grid.Column="1" Margin="5,0,0,0"
                                                    hc:InfoElement.Placeholder="输入配置名称"/>
                                    </Grid>

                                    <!-- Action Buttons - First Row -->
                                    <Grid Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="btnSaveConfig" Content="创建新的" Grid.Column="0" 
                                                Margin="5,0,5,0" Style="{StaticResource ButtonPrimary}"/>
                                        <Button x:Name="btnDeleteConfig" Content="删除" Grid.Column="1" 
                                                Margin="5,0,0,0" Style="{StaticResource ButtonDanger}"/>
                                    </Grid>

                                    <!-- Action Buttons - Second Row (Clipboard Operations) -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="btnImportClipboard" Grid.Column="0" 
                                                Margin="0,0,5,0" Style="{StaticResource ButtonPrimary}">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Path Width="14" Height="14" Margin="0,0,5,0" Stretch="Uniform"
                                                      Data="M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z"
                                                      Fill="{DynamicResource TextIconBrush}"/>
                                                <TextBlock Text="从剪贴板导入"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="btnExportClipboard" Grid.Column="1" 
                                                Margin="5,0,0,0" Style="{StaticResource ButtonPrimary}">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Path Width="14" Height="14" Margin="0,0,5,0" Stretch="Uniform"
                                                      Data="M9,16V10H5L12,3L19,10H15V16H9M5,20V18H19V20H5Z"
                                                      Fill="{DynamicResource TextIconBrush}"/>
                                                <TextBlock Text="导出到剪贴板"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <!-- Reset Button -->
                                    <Button x:Name="btnResetConfig" Content="重置为默认" Margin="0,0,0,0"
                                            HorizontalAlignment="Stretch" Style="{StaticResource ButtonWarning}"/>
                                </hc:SimpleStackPanel>
                            </Expander>
                        </hc:SimpleStackPanel>
                    </ScrollViewer>
                </hc:TabItem>
            </hc:TabControl>

            <!-- Resize handle -->
            <Grid Style="{StaticResource ResizeHandle}"
                  MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown">
                <Path Style="{StaticResource ResizeHandleIcon}"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
