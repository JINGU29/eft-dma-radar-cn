<UserControl x:Class="eft_dma_radar.UI.Pages.GeneralSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blsldrMaxDistanceend/2008" 
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:controls="clr-namespace:eft_dma_radar.UI.Controls"
             mc:Ignorable="d"
             d:DesignHeight="1000" d:DesignWidth="400"
             MinWidth="200" MinHeight="200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header - Draggable area -->
        <Border x:Name="DragHandle" Grid.Row="0" Style="{StaticResource PanelHeader}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="设置" Style="{StaticResource PanelHeaderText}"/>

                <!-- Import/Export Menu Button -->
                <Button x:Name="btnMenu" Tag="ContextMenu"
                        Grid.Column="1" 
                        Width="26" Height="26" Margin="0,0,5,0"
                        Style="{StaticResource ButtonIcon}"
                        ToolTip="导入/导出选项"
                        hc:IconElement.Width="18"
                        hc:IconElement.Geometry="{StaticResource EllipsisVerticalGeometry}">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="ImportExportMenu" 
                                     Placement="Bottom" 
                                     HorizontalOffset="-85"
                                     MaxWidth="200">
                            <MenuItem x:Name="mnuExportConfig" Tag="ExportConfig" Header="导出">
                                <MenuItem.Icon>
                                    <Path Width="14" Height="14"
                                          Stretch="Uniform"
                                          Data="M9,16V10H5L12,3L19,10H15V16H9M5,20V18H19V20H5Z"
                                          Fill="{DynamicResource TextIconBrush}"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator Margin="-28,0,0,0"/>
                            <MenuItem x:Name="mnuImportConfig" Tag="ImportConfig" Header="导入">
                                <MenuItem.Icon>
                                    <Path Width="14" Height="14"
                                          Stretch="Uniform"
                                          Data="M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z"
                                          Fill="{DynamicResource TextIconBrush}"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <!-- Close button -->
                <Border Grid.Column="2" Style="{StaticResource CloseButtonBorder}">
                    <Button x:Name="btnCloseHeader" Style="{StaticResource CloseButton}"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Border Background="{DynamicResource RegionBrush}" 
                    CornerRadius="0,0,8,8"/>

            <hc:TabControl Style="{StaticResource TabControlInLine}"
                          HorizontalContentAlignment="Left"
                          Background="Transparent"
                          BorderThickness="0">

                <!-- 通用设置 -->
                <hc:TabItem Header="通用">
                    <ScrollViewer Style="{StaticResource PanelScrollViewer}">
                        <hc:SimpleStackPanel>
                            <!-- 通用选项 -->
                            <Expander x:Name="expGeneralOptions" Header="通用选项" Style="{StaticResource PanelExpander}" IsExpanded="True">
                                <hc:SimpleStackPanel Style="{StaticResource ExpanderContent}" Margin="2,8,2,0">
                                    <!-- 复选框 -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <CheckBox x:Name="chkMapSetup" Content="显示地图设置" Tag="ShowMapSetup"
                                                  Style="{StaticResource DynamicCheckBoxStyle}" Grid.Row="0" Grid.Column="0" Margin="0,0,5,8"/>
                                        <Button x:Name="btnForceOffsetsUpdate" Content="强制更新偏移"
                                                Tag="ForceOffsetsUpdate"
                                                Style="{StaticResource ButtonPrimary}"
                                                Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                Height="28" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                                    </Grid>

                                    <Grid Margin="0,2,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="雷达帧率限制" Style="{StaticResource LabelText}" 
                                                   VerticalAlignment="Center" Grid.Column="0"/>
                                        <hc:NumericUpDown x:Name="nudFPSLimit" Value="60" Minimum="1" Maximum="500" Tag="FPSLimit"
                                                          Grid.Column="1" Width="70" HorizontalAlignment="Left"/>
                                    </Grid>

                                    <!-- 界面缩放 -->
                                    <hc:SimpleStackPanel Margin="0,5,0,0">
                                        <Grid Margin="0,0,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="界面缩放" Style="{StaticResource LabelText}" 
                                                       VerticalAlignment="Center" Grid.Column="0"/>
                                            <controls:TextValueSlider
                                                x:Name="sldrUIScale" Tag="UIScale"
                                                Minimum="0.5" Maximum="5"
                                                SmallChange="0.1" TickFrequency="0.1"
                                                IsSnapToTickEnabled="True"
                                                ContentStringFormat="{}{0:0.0x}" 
                                                Grid.Column="1"/>
                                        </Grid>
                                    </hc:SimpleStackPanel>

                                    <!-- 窗口组件 -->
                                    <hc:CheckComboBox x:Name="ccbWidgets" Grid.Column="1" Margin="0,5,0,8"
                                                          Style="{StaticResource CheckComboBoxExtend}"
                                                          hc:TitleElement.Title="窗口组件"
                                                          hc:TitleElement.TitlePlacement="Top"
                                                          hc:InfoElement.Placeholder="瞄准视图组件, 调试组件..."/>

                                    <!-- 雷达选项 -->
                                    <hc:CheckComboBox x:Name="ccbGeneralOptions" Grid.Column="1" Margin="0,0,0,0"
                                                          Style="{StaticResource CheckComboBoxExtend}"
                                                          hc:TitleElement.Title="雷达选项"
                                                          hc:TitleElement.TitlePlacement="Top"
                                                          hc:InfoElement.Placeholder="连接队伍, 隐藏名称..."/>
                                </hc:SimpleStackPanel>
                            </Expander>

                            <!-- 字体选择 -->
                            <Expander Header="字体" Style="{StaticResource PanelExpander}" IsExpanded="True">
                                <hc:SimpleStackPanel Style="{StaticResource ExpanderContent}" Margin="2,8,2,8">

                                    <!-- 下拉框 -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="当前字体" Style="{StaticResource LabelText}"
                                                   VerticalAlignment="Center" Grid.Column="0"/>
                                        <ComboBox x:Name="cmbFontSelector"
                                                  Grid.Column="1"
                                                  ToolTip="从 .exe 旁的 fonts/ 文件夹加载字体"/>
                                    </Grid>

                                    <!-- 上传按钮 -->
                                    <Button x:Name="btnUploadFont"
                                            Content="上传字体 (.ttf / .otf)"
                                            Style="{StaticResource ButtonPrimary}"
                                            HorizontalAlignment="Left"
                                            Click="BtnUploadFont_Click"
                                            ToolTip="浏览并添加 .ttf 或 .otf 字体文件到 fonts/ 文件夹"/>

                                    <!-- 删除按钮 -->
                                    <Button x:Name="btnRemoveFont"
                                            Content="删除选中字体"
                                            Style="{StaticResource ButtonDanger}"
                                            HorizontalAlignment="Left"
                                            Margin="0,6,0,0"
                                            Click="BtnRemoveFont_Click"
                                            ToolTip="从 fonts/ 文件夹删除选中字体并恢复为默认字体"/>

                                </hc:SimpleStackPanel>
                            </Expander>

                            <!-- 玩家信息 -->
                            <Expander x:Name="expPlayerInformation" Header="玩家信息" Style="{StaticResource PanelExpander}" IsExpanded="True">
                                <hc:SimpleStackPanel Style="{StaticResource ExpanderContent}" Margin="2,8,2,0">
                                    <!-- 玩家类型选择 -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="玩家类型" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                                        <hc:ComboBox x:Name="cboPlayerType" Grid.Column="1"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <CheckBox x:Name="chkHeightIndicator" Content="高度指示器" Tag="PlayerHeightIndicator"
                                                  Grid.Row="0" Grid.Column="0" Margin="0,0,5,8"
                                                  Style="{StaticResource DynamicCheckBoxStyle}"/>

                                        <CheckBox x:Name="chkImportantIndicator" Content="重要指示器" Tag="ImportantIndicator"
                                                  Grid.Row="0" Grid.Column="1" Margin="5,0,0,8"
                                                  Style="{StaticResource DynamicCheckBoxStyle}"/>

                                        <CheckBox x:Name="chkHighAlert" Content="高级警报" Tag="HighAlert"
                                                  Grid.Row="1" Grid.Column="0" Margin="0,0,5,8"
                                                  Style="{StaticResource DynamicCheckBoxStyle}"/>

                                        <CheckBox x:Name="chkShowImportantPlayerLoot" Content="显示重要战利品" Tag="ShowImportantPlayerLoot"
                                                  Grid.Row="1" Grid.Column="1" Margin="5,0,0,8"
                                                  Style="{StaticResource DynamicCheckBoxStyle}"/>
                                    </Grid>

                                    <!-- 渲染距离 -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="渲染距离" Style="{StaticResource LabelText}" 
                                                   VerticalAlignment="Center" Grid.Column="0"/>
                                        <controls:TextValueSlider
                                            x:Name="sldrPlayerTypeRenderDistance" Tag="PlayerTypeRenderDistance"
                                            Minimum="0" Maximum="1500"
                                            MinContent="关闭" MaxContent="最大"
                                            SmallChange="1" TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            ContentStringFormat="{}{0:0m}" 
                                            Grid.Column="1"/>
                                    </Grid>

                                    <!-- 瞄准线长度 -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="瞄准线长度" Style="{StaticResource LabelText}" 
                                                   VerticalAlignment="Center" Grid.Column="0"/>
                                        <controls:TextValueSlider
                                            x:Name="sldrPlayerTypeAimlineLength" Tag="PlayerTypeAimlineLength"
                                            Minimum="0" Maximum="1000"
                                            MinContent="关闭" MaxContent="最大"
                                            SmallChange="1" TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            ContentStringFormat="{}{0:0m}" 
                                            Grid.Column="1"/>
                                    </Grid>

                                    <hc:SimpleStackPanel x:Name="playerSpecificSettings" Margin="0,0,0,0">
                                        <!-- KD 设置 -->
                                        <Grid x:Name="kdSettings" Visibility="Collapsed" Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="最低 KD" Style="{StaticResource LabelText}" 
                                                VerticalAlignment="Center" Grid.Column="0"/>
                                            <controls:TextValueSlider
                                                x:Name="sldrMinimumKD" Tag="MinimumKD"
                                                Minimum="0.1" Maximum="15.0"
                                                SmallChange="0.1" TickFrequency="0.1"
                                                IsSnapToTickEnabled="True"
                                                ContentStringFormat="{}{0:0.0}" 
                                                Grid.Column="1"/>
                                        </Grid>
                                    </hc:SimpleStackPanel>

                                    <!-- 信息选择 -->
                                    <hc:CheckComboBox x:Name="ccbInformation" Grid.Column="1" Margin="0,0,0,0"
                                                          Style="{StaticResource CheckComboBoxExtend}"
                                                          hc:TitleElement.Title="信息"
                                                          hc:TitleElement.TitlePlacement="Top"
                                                          hc:InfoElement.Placeholder="名称, 血量, 高度, 距离, 标签..."/>
                                </hc:SimpleStackPanel>
                            </Expander>

                            <!-- 实体信息 -->
                            <Expander x:Name="expEntityInformation" Header="实体信息" Style="{StaticResource PanelExpander}" IsExpanded="True">
                                <hc:SimpleStackPanel Style="{StaticResource ExpanderContent}" Margin="2,8,2,0">
                                    <!-- 实体类型选择 -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="实体类型" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                                        <hc:ComboBox x:Name="cboEntityType" Grid.Column="1"/>
                                    </Grid>

                                    <hc:SimpleStackPanel x:Name="entitySpecificSettings" Margin="0,0,0,0">
                                        <!-- 尸体设置 -->
                                        <Grid x:Name="corpseSettings" Visibility="Collapsed">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox x:Name="chkShowImportantCorpseLoot" Content="显示重要战利品" Tag="ShowImportantCorpseLoot"
                                                      Style="{StaticResource DynamicCheckBoxStyle}" Grid.Column="0" Margin="0,0,5,8"/>
                                        </Grid>
                                        
                                        <!-- 手雷设置 -->
                                        <Grid x:Name="grenadeSettings" Visibility="Collapsed">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox x:Name="chkExplosiveRadius" Content="显示半径" Tag="ShowExplosiveRadius"
                                                      Style="{StaticResource DynamicCheckBoxStyle}" Grid.Column="0" Margin="0,0,5,8"/>
                                        </Grid>

                                        <!-- 门设置 -->
                                        <Grid x:Name="doorSettings" Visibility="Collapsed">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox x:Name="chkShowLockedDoors" Content="显示锁定" Tag="ShowLockedDoors"
                                                      Style="{StaticResource DynamicCheckBoxStyle}" Grid.Column="0" Margin="0,0,5,8"/>
                                            <CheckBox x:Name="chkShowUnlockedDoors" Content="显示未锁定" Tag="ShowUnlockedDoors"
                                                      Style="{StaticResource DynamicCheckBoxStyle}" Grid.Column="1" Margin="0,0,5,8"/>
                                        </Grid>

                                        <!-- 撤离点设置 -->
                                        <Grid x:Name="exfilSettings" Visibility="Collapsed">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox x:Name="chkHideInactive" Content="隐藏未激活" Tag="HideInactiveExfils"
                                                      Style="{StaticResource DynamicCheckBoxStyle}" Grid.Column="0" Margin="0,0,5,8"/>
                                        </Grid>

                                        <!-- 绊线设置 -->
                                        <Grid x:Name="tripwireSettings" Visibility="Collapsed">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox x:Name="chkShowTripwireLine" Content="显示绊线" Tag="ShowTripwireLine"
                                                      Style="{StaticResource DynamicCheckBoxStyle}" Grid.Column="0" Margin="0,0,5,8"/>
                                        </Grid>
                                    </hc:SimpleStackPanel>

                                    <!-- 渲染距离 -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="渲染距离" Style="{StaticResource LabelText}" 
                                                   VerticalAlignment="Center" Grid.Column="0"/>
                                        <controls:TextValueSlider
                                            x:Name="sldrEntityTypeRenderDistance" Tag="EntityTypeRenderDistance"
                                            Minimum="0" Maximum="1500"
                                            MinContent="关闭" MaxContent="最大"
                                            SmallChange="1" TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            ContentStringFormat="{}{0:0m}" 
                                            Grid.Column="1"/>
                                    </Grid>

                                    <!-- 信息选择 -->
                                    <hc:CheckComboBox x:Name="ccbEntityInformation" Grid.Column="1" Margin="0,0,0,0"
                                                      Style="{StaticResource CheckComboBoxExtend}"
                                                      hc:TitleElement.Title="信息"
                                                      hc:TitleElement.TitlePlacement="Top"
                                                      hc:InfoElement.Placeholder="名称, 距离, 高度, 价值..."/>
                                </hc:SimpleStackPanel>
                            </Expander>

                            <!-- 显示器设置 -->
                            <Expander x:Name="expMonitorSettings" Header="显示器设置" Style="{StaticResource PanelExpander}" IsExpanded="True">
                                <hc:SimpleStackPanel Style="{StaticResource ExpanderContent}" Margin="2,8,2,0">
                                    <!-- 显示器选择 -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="显示器" Style="{StaticResource LabelText}" 
                                                   VerticalAlignment="Center" Grid.Column="0"/>

                                        <Button x:Name="btnRefreshMonitors" Tag="RefreshMonitors" 
                                                Grid.Column="1"
                                                Style="{StaticResource ButtonIcon}"
                                                Width="40" Height="28"
                                                ToolTip="刷新显示器"
                                                hc:IconElement.Geometry="{StaticResource RotateRightGeometry}"
                                                hc:IconElement.Width="18"
                                                hc:IconElement.Height="18"/>

                                        <hc:ComboBox x:Name="cboMonitor" Tag="Monitor"
                                                     Grid.Column="2"/>
                                    </Grid>

                                    <!-- 融合器宽度 -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="宽度" Style="{StaticResource LabelText}" 
                                                   VerticalAlignment="Center" Grid.Column="0"/>

                                        <hc:TextBox x:Name="txtGameWidth" Grid.Column="1" Tag="GameWidth"
                                                    Text="1920"
                                                    hc:InfoElement.Placeholder="1920"/>
                                    </Grid>

                                    <!-- 融合器高度 -->
                                    <Grid Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="高度" Style="{StaticResource LabelText}" 
                                                   VerticalAlignment="Center" Grid.Column="0"/>

                                        <hc:TextBox x:Name="txtGameHeight" Grid.Column="1" Tag="GameHeight"
                                                    Text="1080"
                                                    hc:InfoElement.Placeholder="1080"/>
                                    </Grid>
                                </hc:SimpleStackPanel>
                            </Expander>

                            <!-- 任务助手 -->
                            <Expander x:Name="expQuestHelper" Header="任务助手" Style="{StaticResource PanelExpander}" IsExpanded="True">
                                <hc:SimpleStackPanel Style="{StaticResource ExpanderContent}" Margin="2,8,2,0">
                                    <CheckBox x:Name="chkQuestHelper" Content="启用" Tag="QuestHelper"
                                                  Style="{StaticResource DynamicCheckBoxStyle}" 
                                                  Margin="0,0,0,10"/>
                                    
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Style="{StaticResource ContainerListBorder}">
                                            <ScrollViewer MaxHeight="250" VerticalScrollBarVisibility="Auto">
                                                <ListBox x:Name="listQuests" Margin="0,0,10,0"
                                                         ItemsSource="{Binding QuestItems}"
                                                         Style="{StaticResource ContainerListBox}">
                                                    <ListBox.ItemContainerStyle>
                                                        <StaticResource ResourceKey="ContainerListBoxItem"/>
                                                    </ListBox.ItemContainerStyle>
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <CheckBox Content="{Binding Name}"
                                                                      Style="{StaticResource DynamicCheckBoxStyle}"
                                                                      IsChecked="{Binding IsSelected}"
                                                                      ToolTip="{Binding DebugTooltip}"
                                                                      Checked="QuestListItem_CheckChanged"
                                                                      Unchecked="QuestListItem_CheckChanged"/>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </ScrollViewer>
                                        </Border>

                                        <hc:SimpleStackPanel Grid.Column="1" VerticalAlignment="Top" Margin="10,0,0,0">
                                            <CheckBox x:Name="chkQuestsSelectAll" Content="全选" Tag="QuestsSelectAll"
                                                  Style="{StaticResource DynamicCheckBoxStyle}" 
                                                  Grid.Column="1" Margin="0,0,0,8"/>

                                            <CheckBox x:Name="chkKappaFilter" Content="卡帕任务过滤" Tag="KappaFilter"
                                                  Style="{StaticResource DynamicCheckBoxStyle}" 
                                                  Grid.Column="1" Margin="0,0,0,8"/>

                                            <CheckBox x:Name="chkOptionalTaskFilter" Content="可选任务" Tag="OptionalTaskFilter"
                                                  Style="{StaticResource DynamicCheckBoxStyle}" 
                                                  Grid.Column="1" Margin="0,0,0,8"/>

                                            <CheckBox x:Name="chkKillZones" Content="击杀区域" Tag="KillZones"
                                                  Style="{StaticResource DynamicCheckBoxStyle}" 
                                                  Grid.Column="1"/>
                                        </hc:SimpleStackPanel>
                                    </Grid>
                                </hc:SimpleStackPanel>
                            </Expander>

                            <!-- 网络雷达服务器 -->
                            <Expander x:Name="expWebRadar" Header="网络雷达服务器" Style="{StaticResource PanelExpander}" IsExpanded="True">
                                <hc:SimpleStackPanel Style="{StaticResource ExpanderContent}" Margin="2,8,2,0">
                                    <!-- 启动按钮, UPnP 复选框 & 链接标签 -->
                                    <Grid Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Button x:Name="btnWebRadarStart" Content="启动" Width="80" Height="28"
                                                Style="{StaticResource ButtonPrimary}"/>

                                        <CheckBox x:Name="chkWebRadarUPnP" Content="UPnP"  Tag="UPnP"
                                                  Style="{StaticResource DynamicCheckBoxStyle}" Grid.Column="1" Margin="10,0,0,0" 
                                                  VerticalAlignment="Center"/>

                                        <TextBlock x:Name="lblWebRadarLink" Text="http://" Foreground="{DynamicResource InfoBrush}" 
                                                   TextWrapping="Wrap" Margin="10,5,0,5" Grid.Column="2"
                                                   Cursor="Hand" TextDecorations="Underline"/>
                                    </Grid>

                                    <!-- 绑定 IP & 端口 -->
                                    <Grid Margin="0,8,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- 端口标签 -->
                                        <TextBlock Text="端口" Style="{StaticResource LabelText}" 
                                                   VerticalAlignment="Center" Grid.Column="3" Grid.Row="0" Margin="15,0,5,0"/>

                                        <!-- 端口文本框 -->
                                        <hc:TextBox x:Name="txtWebRadarPort" Width="80" Tag="WebRadarPort"
                                                    Grid.Column="4" Grid.Row="0"
                                                    hc:InfoElement.Placeholder="8080"/>
                                    </Grid>
                                </hc:SimpleStackPanel>
                            </Expander>

                            <!-- 玩家 API 服务 -->
                            <Expander x:Name="expPlayerAPIService" Header="玩家 API 服务" Style="{StaticResource PanelExpander}" IsExpanded="True">
                                <hc:SimpleStackPanel Style="{StaticResource ExpanderContent}" Margin="2,8,2,0">

                                    <!-- API 提供商选择 -->
                                    <Grid Margin="0,0,0,10" HorizontalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <RadioButton x:Name="rdbTarkovDev" Content="tarkov.dev"
                                                     GroupName="APIProvider" Tag="TarkovDev"
                                                     Grid.Column="0" Margin="0,0,20,0"/>

                                        <RadioButton x:Name="rdbEftApiTech" Content="eft-api.tech"
                                                     GroupName="APIProvider" Tag="EftApiTech"
                                                     Grid.Column="1" IsChecked="True"/>
                                    </Grid>

                                    <!-- API 管理控件 (仅对 eft-api.tech 可见) -->
                                    <StackPanel Margin="0,0,0,8">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
